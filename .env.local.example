# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Cron security (must match Authorization: Bearer <secret> header)
CRON_SECRET=<your-cron-secret>

# Upstash Redis — rate limiting (optional; rate limiting is disabled if unset)
# Create a database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Email (Resend)
RESEND_API_KEY=<resend-api-key>
